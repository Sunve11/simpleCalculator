<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="10.0" styleClass="calculator-root"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="denisarseny.simplecalculator.view.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="12.0"/>
    </padding>

    <MenuBar fx:id="menuBar" useSystemMenuBar="true"/>

    <HBox alignment="CENTER" spacing="10.0">
        <ImageView fx:id="logoView" fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true"/>
        <Label fx:id="titleLabel" styleClass="calculator-title" text="SIMPLE CALCULATOR"/>
    </HBox>

    <TextField fx:id="display" editable="false" focusTraversable="false" promptText="0"
               styleClass="calculator-display" VBox.vgrow="NEVER"/>

    <HBox alignment="CENTER" spacing="8.0" styleClass="toolbar-row">
        <Button fx:id="buttonUndo" mnemonicParsing="false" onAction="#handleUndo" styleClass="calc-btn-util"
                text="Отмена"/>
        <Button fx:id="buttonRedo" mnemonicParsing="false" onAction="#handleRedo" styleClass="calc-btn-util"
                text="Повтор"/>
        <Button fx:id="buttonShowHistory" mnemonicParsing="false" onAction="#handleShowHistory"
                styleClass="calc-btn-util" text="История"/>
        <Button fx:id="buttonClearHistory" mnemonicParsing="false" onAction="#handleClearHistory"
                styleClass="calc-btn-util" text="Журнал"/>
    </HBox>

    <GridPane fx:id="keypad" hgap="10.0" styleClass="keypad" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="72.0" percentWidth="25.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="72.0" percentWidth="25.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="72.0" percentWidth="25.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="72.0" percentWidth="25.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="56.0" prefHeight="56.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="56.0" prefHeight="56.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="56.0" prefHeight="56.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="56.0" prefHeight="56.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="56.0" prefHeight="56.0" vgrow="SOMETIMES"/>
        </rowConstraints>

        <Button mnemonicParsing="false" onAction="#handleClear" styleClass="calc-btn, calc-btn-clear" text="C"
                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button mnemonicParsing="false" onAction="#handleOpenBracket" styleClass="calc-btn, calc-btn-accent" text="("
                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button mnemonicParsing="false" onAction="#handleCloseBracket" styleClass="calc-btn, calc-btn-accent" text=")"
                GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Button mnemonicParsing="false" onAction="#handleOperation" styleClass="calc-btn, calc-btn-op" text="/"
                GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="7"
                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="8"
                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="9"
                GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Button mnemonicParsing="false" onAction="#handleOperation" styleClass="calc-btn, calc-btn-op" text="*"
                GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="4"
                GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="5"
                GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="6"
                GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <Button mnemonicParsing="false" onAction="#handleOperation" styleClass="calc-btn, calc-btn-op" text="-"
                GridPane.columnIndex="3" GridPane.rowIndex="2"/>

        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="1"
                GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="2"
                GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="3"
                GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        <Button mnemonicParsing="false" onAction="#handleOperation" styleClass="calc-btn, calc-btn-op" text="+"
                GridPane.columnIndex="3" GridPane.rowIndex="3"/>

        <Button mnemonicParsing="false" onAction="#handleSign" styleClass="calc-btn, calc-btn-accent" text="±"
                GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <Button mnemonicParsing="false" onAction="#handleNumber" styleClass="calc-btn, calc-btn-digit" text="0"
                GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Button mnemonicParsing="false" onAction="#handleDot" styleClass="calc-btn, calc-btn-digit" text="."
                GridPane.columnIndex="2" GridPane.rowIndex="4"/>
        <Button mnemonicParsing="false" onAction="#handleEquals" styleClass="calc-btn, calc-btn-equals" text="="
                GridPane.columnIndex="3" GridPane.rowIndex="4"/>
    </GridPane>
</VBox>
